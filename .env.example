# MathForge 环境变量示例
# 复制为 .env 后填入实际值

# 服务
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# 数据库
DATABASE_PATH=data/vault.db

# LLM（OpenAI 兼容）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# OCR（PaddleOCR）
PADDLEOCR_API_URL=
PADDLEOCR_TOKEN=

# 提示词路径
PROMPTS_DIR=prompts
