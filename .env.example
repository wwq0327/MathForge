# MathForge 环境变量示例
# 复制为 .env 后填入实际值（不要把含真实密钥的 .env 提交）

# ── 服务 ──
APP_HOST=0.0.0.0                          # 监听地址；本机调试可用 127.0.0.1
APP_PORT=8000                             # 监听端口
APP_DEBUG=false                           # 选填；true 开启 FastAPI debug + uvicorn --reload，生产请保持 false

# ── 数据库 ──
DATABASE_PATH=data/vault.db               # 相对项目根；父目录不存在会自动创建

# ── LLM（OpenAI 兼容）──
LLM_BASE_URL=https://api.deepseek.com/v1  # OpenAI 兼容的 base_url
LLM_API_KEY=                              # 必填（P1+ 录入流程用到）；留空时调用方会在运行时失败
LLM_MODEL=deepseek-chat                   # 模型名

# ── OCR（PaddleOCR）──
PADDLEOCR_API_URL=                        # 选填（P4 阶段使用）；自托管 PaddleOCR 服务地址
PADDLEOCR_TOKEN=                          # 选填；与 PADDLEOCR_API_URL 配套

# ── 提示词 ──
PROMPTS_DIR=prompts                       # 相对项目根；存放 *.txt 提示词模板，支持热重载
